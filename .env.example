# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Optional — override the judge model (default: claude-sonnet-4-6)
# EVAL_JUDGE_MODEL=claude-sonnet-4-6

# Optional — override the agent model (default: claude-haiku-4-5)
# DRL_MODEL=claude-haiku-4-5

# Optional — max agent steps per question (default: 12)
# DRL_MAX_STEPS=12
